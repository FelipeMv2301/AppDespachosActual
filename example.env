STARKEN_PORTAL_HOST=HOST
STARKEN_PORTAL_USER=USER
STARKEN_PORTAL_PASS=PASS
STARKEN_API_HOST=HOST
STARKEN_API_KEY=API_KEY
STARKEN_WS_URL=URL

# Google Chat data
# ------------------------------------------------------------------------------
