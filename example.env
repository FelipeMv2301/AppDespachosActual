# Django setup
# ------------------------------------------------------------------------------
SETTINGS_MODULE='core.settings.local'
DEBUG_MODE=True
LANGUAGE_CODE=es
TIME_ZONE=America/Santiago
USE_TIME_ZONE=False
USE_I18N=True
SECRET_KEY=KEY
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost
INTERNAL_IPS=127.0.0.1,localhost
SESSION_COOKIE_AGE=3600

# Database for Django
# ------------------------------------------------------------------------------
DB_ENGINE=django.db.backends.mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=despachos
DB_USER=USER_HERE
DB_PASSWORD=PASSWD_HERE

# SAP data
# ------------------------------------------------------------------------------
SAP_HOST=URL
SAP_USER=USER
SAP_PASS=PASS
SAP_DATABASE=DB

# Starken data
