alias apache="sudo service apache2 stop && sudo service apache2 start"
alias app="python3 manage.py startapp"
alias dump="python3 manage.py dumpdata"
alias exe="python3 manage.py shell <"
alias load="python3 manage.py loaddata"
alias makemig="python3 manage.py makemigrations"
alias mig="python3 manage.py migrate"
alias py3="python3 -m"
alias run="python3 manage.py runserver"
alias shell="python3 manage.py shell"
alias shell="python3 manage.py shell"
alias shellplus="python3 manage.py shell_plus"
alias static="python3 manage.py collectstatic"
alias user="python3 manage.py createsuperuser"
alias venv="source venv/bin/activate"